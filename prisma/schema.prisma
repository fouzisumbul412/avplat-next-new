generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?
  role     Role    @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ZohoAuth {
  id          String   @id @default("zoho_token")
  accessToken String   @db.Text
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt
}

model QuoteRequest {
  id String @id @default(uuid())

  fullName String
  phone    String
  email    String
  subject  String
  services String[]
  message  String @db.Text

  zohoSynced Boolean  @default(false)
  zohoId     String?
  createdAt  DateTime @default(now())
}

model CharterRequest {
  id String @id @default(uuid())

  name          String
  email         String
  phone         String
  departure     String
  arriving      String
  passengers    String
  departureDate DateTime
  returnDate    DateTime?

  zohoSynced Boolean  @default(false)
  zohoId     String?
  createdAt  DateTime @default(now())
}

model HomeContent {
  id           String   @id @default("home_content")
  titleBlack   String   @default("Why")
  titleBlue    String   @default("AvPlat")
  description  String   @db.Text
  videoUrl     String
  appStoreUrl  String?
  playStoreUrl String?

  updatedAt    DateTime @updatedAt

  items        HomeSectionItem[]
}

enum HomeSectionType {
  FAQ
  CAROUSEL
  SERVICES
  REWIRED
}

model HomeSectionItem {
  id          String   @id @default(uuid())
  homeId      String   @default("home_content")
  
  section     HomeSectionType
  order       Int      @default(0)
  
  title       String
  description String   @db.Text
  image       String?
  link        String?
  
  home        HomeContent @relation(fields: [homeId], references: [id], onDelete: Cascade)
}

enum AccentColor {
  blue
  slate
}

enum FeatureLayout {
  leftText
  rightText
  centerSplit
}

model FeaturePage {
  id String @id @default(uuid())
  slug String @unique
  
  pageTitle String   
  heroImage String?  
  badgeText String?  
  heroTitle String   
  heroDescription String @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stats PageStat[]
  features PageFeature[]
}

model PageStat {
  id String @id @default(uuid())
  pageId String
  order Int @default(0)
  label String
  value String
  
  page FeaturePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model PageFeature {
  id String @id @default(uuid())
  pageId String
  order Int @default(0)
  
  eyebrow String?
  title String
  description String @db.Text
  points String[]
  videoId String?
  icon String?
  accent AccentColor @default(blue)
  layout FeatureLayout @default(leftText)

  page FeaturePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id String @id @default(uuid())

  slug      String  @unique
  title     String
  excerpt   String  @db.Text
  thumbnail String
  category  String
  content   String  @db.Text
  author    String  @default("Skyblue Aero")
  readTime  String  @default("5 min read")
  published Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}